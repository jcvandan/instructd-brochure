# Minimal stack: only what this site uses (avoids the huge github-pages + theme set).
# Windows (RubyInstaller): if a gem fails to build native extensions, run: ridk install
# then re-run: bundle install
source "https://rubygems.org"

gem "jekyll", "~> 4.3"
gem "webrick", "~> 1.8"

group :jekyll_plugins do
  gem "jekyll-feed", "~> 0.17"
  gem "jekyll-sitemap", "~> 1.4"
  gem "jekyll-seo-tag", "~> 2.8"
end
